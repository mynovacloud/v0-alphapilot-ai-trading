# AlphaPilot AI - Environment Variables Example
# Copy this file to `.env` and fill in real values when you are ready.
# DO NOT commit your real .env file.

APP_ENV=development
APP_NAME=AlphaPilot AI
APP_DEBUG=true

# Database
DATABASE_URL=sqlite:///./alphapilot.db

# Backend API
API_HOST=127.0.0.1
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501

# Live trading (locked by default - DO NOT enable until risk controls are reviewed)
LIVE_TRADING_ENABLED=false

# --- Future API credentials (placeholders only) ---
# These are stored locally only for paper-trading mocking.
# Real credentials should be encrypted before storage in production.
POLYMARKET_API_KEY=
KALSHI_API_KEY=
WEBULL_API_KEY=
CRYPTOCOM_API_KEY=
ROBINHOOD_API_KEY=
ETRADE_API_KEY=
COINBASE_API_KEY=
BINANCE_API_KEY=
KRAKEN_API_KEY=
FIDELITY_API_KEY=
IBKR_API_KEY=
